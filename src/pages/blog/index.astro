---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Blog | Bee-jay Paiz" description="Writing on web development and side projects.">
  <Header slot="header" />
  <div class="flex flex-col pb-16 pt-10">
    <h1 class="text-3xl font-semibold tracking-tight text-chatelle-50">Blog</h1>
    <p class="mt-2 text-sm text-mountain-mist-400">Notes on shipping and the stack.</p>
    <div class="mt-12 flex w-full max-w-2xl flex-col">
      {
        posts.map((post, i) => (
          <a href={`${base}blog/${post.id}/`} class="group block">
            <article
              class:list={['py-8 transition', i > 0 && 'border-t border-mountain-mist-900']}
            >
              {post.data.heroImage ? (
                <img
                  src={post.data.heroImage}
                  alt=""
                  class="mb-5 max-h-40 w-full border border-mountain-mist-900 object-cover"
                  width="800"
                  height="400"
                />
              ) : null}
              <h2 class="text-lg font-medium text-chatelle-50 group-hover:text-eucalyptus-400">
                {post.data.title}
              </h2>
              <p class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-xs text-mountain-mist-400">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-GB', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
                <span>· {post.data.author}</span>
              </p>
              {post.data.description ? (
                <p class="mt-3 line-clamp-2 text-sm leading-relaxed text-mountain-mist-300">
                  {post.data.description}
                </p>
              ) : null}
            </article>
          </a>
        ))
      }
    </div>
  </div>
  <Footer slot="footer" />
</BaseLayout>
