---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Page not found | Bee-jay Paiz">
  <Header slot="header" />
  <div class="flex flex-col items-center justify-center gap-4 py-24 text-center">
    <p class="text-xs font-semibold uppercase tracking-widest text-mountain-mist-500">404</p>
    <h1 class="text-2xl font-semibold text-chatelle-50">Page not found</h1>
    <p class="max-w-sm text-sm text-mountain-mist-400">That URL does not match anything here.</p>
    <a
      href={`${base}`}
      class="mt-2 text-sm font-medium text-eucalyptus-400 transition hover:text-eucalyptus-300"
    >
      ← Back home
    </a>
  </div>
  <Footer slot="footer" />
</BaseLayout>
