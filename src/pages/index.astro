---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

const base = import.meta.env.BASE_URL;

const aboutIntro = [
  `I'm a full-stack developer in Glasgow, Scotland—Shopify themes, headless storefronts, and lately React Native and embedded Shopify apps. I care about performance, clear UX, and systems that stay maintainable.`,
  `Before engineering I taught math and ESL, wrote poetry, and drove a forklift. That mix shapes how I communicate, structure problems, and ship.`,
];

const focusAreas = [
  'Shopify: Liquid themes, Storefront / Customer Account APIs, admin & account UI extensions',
  'Mobile: Expo, Apollo GraphQL, Firebase, EAS',
  'Web: TypeScript, React, Vue/Nuxt, Tailwind',
];
---

<BaseLayout title="Bee-jay Paiz | Full-stack Web Developer">
  <Header slot="header" />
  <div class="pb-20 pt-12 md:pt-16">
    <section class="flex flex-col items-center gap-12 lg:flex-row lg:items-start lg:justify-between lg:gap-16">
      <div class="shrink-0 ring-1 ring-white/10 ring-offset-4 ring-offset-mountain-mist-950">
        <img
          src="https://res.cloudinary.com/dgclfs5cd/image/upload/f_auto,q_auto/slwq02fofmxbbd1plvrd"
          class="h-44 w-44 object-cover sm:h-52 sm:w-52 bg-white/80 rounded-sm"
          alt="Bee-jay Paiz"
          width="208"
          height="208"
        />
      </div>
      <div class="max-w-xl flex-1 text-center lg:text-left">
        <p class="text-sm font-medium tracking-wide text-mountain-mist-400">Full-stack · Glasgow</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-chatelle-50 sm:text-5xl">
          Bee-jay Paiz
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-mountain-mist-200">
          I build fast, accessible commerce experiences—from storefronts and themes to mobile apps and
          Shopify admin tooling.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3 lg:justify-start">
          <a
            href={`${base}projects/`}
            class="rounded-full bg-chatelle-50 px-5 py-2.5 text-sm font-medium text-mountain-mist-950 transition hover:bg-mountain-mist-100"
          >
            View projects
          </a>
          <a
            href={`${base}blog/`}
            class="rounded-full border border-mountain-mist-900 px-5 py-2.5 text-sm font-medium text-chatelle-50 transition hover:border-mountain-mist-700 hover:bg-white/5"
          >
            Blog
          </a>
          <a
            href={`${base}bj_cv_webdev.pdf`}
            class="text-sm font-medium text-eucalyptus-400 underline-offset-4 transition hover:text-eucalyptus-300 hover:underline"
            target="_blank"
            rel="noreferrer"
          >
            Download résumé (PDF)
          </a>
        </div>
      </div>
    </section>

    <div id="about" class="mt-24 max-w-2xl scroll-mt-24">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-mountain-mist-400">About</h2>
      <div class="mt-6 space-y-5 text-base leading-relaxed text-mountain-mist-200">
        {aboutIntro.map((text) => <p>{text}</p>)}
      </div>
      <ul class="mt-8 space-y-3 border-l border-mountain-mist-900 pl-5 text-sm leading-relaxed text-mountain-mist-300">
        {focusAreas.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </div>
  <Footer slot="footer" />
</BaseLayout>
