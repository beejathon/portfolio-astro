---
const year = new Date().getFullYear();

const link =
  'text-sm text-mountain-mist-400 transition hover:text-eucalyptus-400';
---

<footer class="mt-auto border-t border-mountain-mist-900 py-10">
  <div class="flex flex-col items-center justify-between gap-6 sm:flex-row sm:items-start">
    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 sm:justify-start">
      <a href="mailto:beejay@paiz.dev" class={link}>beejay@paiz.dev</a>
      <a href="https://github.com/beejathon" target="_blank" rel="noreferrer" class={link}>GitHub</a>
      <a
        href="https://www.linkedin.com/in/bee-jay-paiz-aa20253a/"
        target="_blank"
        rel="noreferrer"
        class={link}
      >
        LinkedIn
      </a>
      <a href={`${import.meta.env.BASE_URL}bj_cv_webdev.pdf`} class={link} target="_blank" rel="noreferrer">
        Résumé PDF
      </a>
    </div>
    <p class="text-center text-xs text-mountain-mist-500 sm:text-right">&copy; {year} Bee-jay Paiz</p>
  </div>
</footer>
