---
const year = new Date().getFullYear();
---

<footer class="flex flex-col items-center gap-2 py-8">
  <h2 class="font-mono text-xl font-bold uppercase text-eucalyptus-500">Get in touch:</h2>
  <div class="flex items-center justify-center gap-10">
    <a href="mailto:beejay@paiz.dev" aria-label="Email">
      <span class="material-symbols-outlined pt-1 text-[48px] text-white">send</span>
    </a>
    <a href="https://github.com/beejathon" target="_blank" rel="noreferrer" aria-label="GitHub">
      <img
        class="h-10"
        src="https://res.cloudinary.com/dgclfs5cd/image/upload/f_auto,q_auto/oejvfeio5urqc8b0q2xj"
        alt=""
        width="40"
        height="40"
      />
    </a>
    <a
      href="https://www.linkedin.com/in/bee-jay-paiz-aa20253a/"
      target="_blank"
      rel="noreferrer"
      aria-label="LinkedIn"
    >
      <img
        class="h-10"
        src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/linkedin/linkedin-original.svg"
        alt=""
        width="40"
        height="40"
      />
    </a>
  </div>
