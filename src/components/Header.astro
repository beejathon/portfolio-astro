---
const base = import.meta.env.BASE_URL;
---

<header class="flex w-full justify-between py-4">
  <div class="ml-10 flex items-center gap-10">
    <a href={`${base}`} class="text-2xl font-bold text-eucalyptus-500"> Bee-jay Paiz </a>
    <nav class="hidden gap-10 lg:flex">
      <a href={`${base}#about`} class="text-xl font-light text-eucalyptus-500"> About </a>
      <a href={`${base}projects/`} class="text-xl font-light text-eucalyptus-500"> Projects </a>
      <a href={`${base}bj_cv_webdev.pdf`} class="text-xl font-light text-eucalyptus-500" target="_blank" rel="noreferrer">
        CV
      </a>
    </nav>
  </div>
  <div class="mr-10 hidden lg:block">
    <a href={`${base}blog/`} class="text-xl font-light text-eucalyptus-500"> Blog </a>
  </div>
  <details class="nav-drawer mr-10 lg:hidden" id="site-nav-drawer">
    <summary
      class="list-none cursor-pointer [&::-webkit-details-marker]:hidden"
      aria-label="Open menu"
    >
      <span class="material-symbols-outlined text-4xl text-eucalyptus-500">menu</span>
    </summary>
    <div class="fixed inset-0 z-50 bg-mountain-mist-950/98 px-6 pt-6">
      <div class="flex justify-end">
        <button
          type="button"
          class="text-eucalyptus-500"
          aria-label="Close menu"
          onclick="document.getElementById('site-nav-drawer')?.removeAttribute('open')"
        >
          <span class="material-symbols-outlined text-4xl">close</span>
        </button>
      </div>
      <nav class="mt-10 flex flex-col gap-10 pl-2">
        <a
          href={`${base}#about`}
          class="text-xl font-light text-eucalyptus-500"
          onclick="document.getElementById('site-nav-drawer')?.removeAttribute('open')"
        >
          About
        </a>
        <a
          href={`${base}projects/`}
          class="text-xl font-light text-eucalyptus-500"
          onclick="document.getElementById('site-nav-drawer')?.removeAttribute('open')"
        >
          Projects
        </a>
        <a
          href={`${base}bj_cv_webdev.pdf`}
          class="text-xl font-light text-eucalyptus-500"
          target="_blank"
          rel="noreferrer"
          onclick="document.getElementById('site-nav-drawer')?.removeAttribute('open')"
        >
          CV
        </a>
        <a
          href={`${base}blog/`}
          class="text-xl font-light text-eucalyptus-500"
          onclick="document.getElementById('site-nav-drawer')?.removeAttribute('open')"
        >
          Blog
        </a>
      </nav>
    </div>
  </details>
</header>
