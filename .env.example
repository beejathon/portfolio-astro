# Used at build time (astro.config.mjs)
PUBLIC_SITE_URL=https://beejathon.github.io
# Repository path segment for GitHub project pages (trailing slash). Use "/" for username.github.io root site.
PUBLIC_BASE_PATH=/portfolio-astro/

# Add your CV as public/bj_cv_webdev.pdf (or change the path in src/components/Header.astro).

# Giscus (https://giscus.app) — see README "Giscus comments":
#   enable Discussions on a public repo → install github.com/apps/giscus → complete giscus.app form → copy data-* into these vars.
# Optional in post frontmatter: giscusTerm (only needed when PUBLIC_GISCUS_MAPPING=specific and you do not want the default file slug).
PUBLIC_GISCUS_REPO=beejathon/your-repo-name
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=Announcements
PUBLIC_GISCUS_CATEGORY_ID=
PUBLIC_GISCUS_MAPPING=pathname
PUBLIC_GISCUS_THEME=dark
PUBLIC_GISCUS_LANG=en
